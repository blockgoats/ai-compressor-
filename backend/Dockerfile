FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-api.txt setup.py README.md MANIFEST.in ./
COPY ramanujan_compression ./ramanujan_compression
COPY ramanujan_tokenizer ./ramanujan_tokenizer
COPY ramanujan_pro ./ramanujan_pro
COPY ramanujan_cli ./ramanujan_cli
COPY app ./app
COPY scripts ./scripts

ENV PYTHONPATH=/app
ENV PYTHONDONTWRITEBYTECODE=1

RUN pip install --no-cache-dir -e . && pip install --no-cache-dir -r requirements-api.txt

EXPOSE 8000

CMD ["sh", "-c", "python scripts/init_db.py && uvicorn app.main:app --host 0.0.0.0 --port 8000"]
