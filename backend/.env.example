# Copy to .env and adjust

# API
DEBUG=false
AUTH_DISABLE=true
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Database (async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://ram:ram@localhost:5432/ramanujan
SYNC_DATABASE_URL=postgresql://ram:ram@localhost:5432/ramanujan

# Redis — for local API dev you can omit; use Docker network URL when running worker in compose
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Tokenizer for compression pipeline (HuggingFace id)
BASE_TOKENIZER_NAME=bert-base-uncased

# LLM (optional — for POST /api/v1/generate)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
LLM_PROVIDER=openai
